---
import HeroButtons from './HeroButtons';
/**
 * HomeHero 组件
 * 负责：动态线条背景、主标题、副标题、行动按钮
 */
interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "方圆之间", 
  subtitle = "服 装 结 构 设 计" 
} = Astro.props;
---

<section class="hero-container">
  <div class="background-wrapper">
    <div class="line" style="top:15%; animation-delay:0s"></div>
    <div class="line" style="top:35%; animation-delay:2s"></div>
    <div class="line" style="top:65%; animation-delay:4s"></div>
  </div>

  <div class="content">
    <h1 class="logo-title">{title}</h1>
    <p class="subtitle">{subtitle}</p>
    <HeroButtons client:load />
  </div>
</section>

<style>
  .hero-container {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    background-color: #0a0a0a;
  }

  /* 动态线条背景 */
  .background-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(circle at center, #1a1a1a 0%, #000 100%);
  }

  .line {
    position: absolute;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    height: 1px;
    width: 100%;
    animation: move 8s infinite linear;
  }

  @keyframes move {
    0% { transform: translateY(-100vh) rotate(45deg); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(100vh) rotate(45deg); opacity: 0; }
  }

  /* 内容层 */
  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .logo-title {
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 200;
    letter-spacing: 15px;
    margin-bottom: 20px;
    text-transform: uppercase;
    background: linear-gradient(to right, #fff, #888);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: fadeIn 3s ease-in-out;
  }

  .subtitle {
    font-size: clamp(0.9rem, 3vw, 1.2rem);
    color: #888;
    letter-spacing: 5px;
    animation: fadeIn 4.5s ease-in-out;
  }

  .action-buttons {
    margin-top: 50px;
    display: flex;
    gap: 20px;
    animation: fadeIn 6s ease-in-out;
  }

  .btn {
    padding: 12px 35px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 2px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(4px);
  }

  .btn-primary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-primary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
  }

  .btn-secondary {
    background: transparent;
    color: #666;
    border: 1px solid #333;
  }

  .btn-secondary:hover {
    color: #fff;
    border-color: #666;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>