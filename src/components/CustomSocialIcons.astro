---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import type { Props } from '@astrojs/starlight/props';

// 🚨 动态读取：打包时 Cloudflare 会自动把这里的代码替换成真实的网址
// 如果本地没配 .env 或者线上没配变量，就默认回退到线上主干地址
const workbenchUrl = import.meta.env.PUBLIC_APP_URL || 'https://ai.fyzj.online';
---

<div class="custom-header-actions">
  <a href={workbenchUrl} target="_blank" class="workbench-btn">
    进入工作台
  </a>
  <Default {...Astro.props} />
</div>

<style>
  .custom-header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .workbench-btn {
    background-color: var(--color-brand-primary);
    color: var(--color-surface-dark) !important; 
    text-decoration: none;
    padding: 0.35rem 1.1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600; 
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.08); 
    white-space: nowrap;
  }

  .workbench-btn:hover {
    background-color: var(--color-brand-primary-light);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
    color: var(--color-surface-dark) !important;
  }
</style>