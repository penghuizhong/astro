---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import type { Props } from '@astrojs/starlight/props';
---

<div class="custom-header-actions">
  <a href="https://app.fyzj.online" target="_blank" class="workbench-btn">
    进入工作台
  </a>
  <Default {...Astro.props} />
</div>

<style>
  .custom-header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .workbench-btn {
    /* 直接调用 global.css 中的变量 */
    background-color: var(--color-brand-primary);
    
    /* 浅色背景必须配深色文字，调用 surface-dark */
    color: var(--color-surface-dark) !important; 
    
    text-decoration: none;
    padding: 0.35rem 1.1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600; /* 加粗一点，在浅色底上更清晰 */
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    
    /* 微弱的银色光晕 */
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.08); 
    white-space: nowrap;
  }

  .workbench-btn:hover {
    /* 悬停时读取变暗一点的银色变量 */
    background-color: var(--color-brand-primary-light);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
    
    /* 保持深色文字 */
    color: var(--color-surface-dark) !important;
  }
</style>