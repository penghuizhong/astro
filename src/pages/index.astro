---
import HomeHero from '../components/HomeHero.astro';
import '../styles/global.css';

const siteUrl = 'https://fyzj.online';
const title = '方圆之间 —— 服装结构设计';
const description = '方圆之间官方门户网站，探索服装结构设计的边界。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
  </head>
  <body>
    
    <HomeHero />

    <footer>
        <p>© 2026 方圆之间 - 服装结构设计</p>
        <div class="beian">
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">粤ICP备2026016614号-1</a>
            <a href="http://www.beian.gov.cn/" target="_blank" rel="noopener">
                <img src="src/assets/备案图标.png" alt="备案图标" />
                粤公网安备44010602015229号
            </a>
        </div>
    </footer>

  </body>
</html>

<style>
  /* 仅针对主页 body 的全局溢出控制 */
  body {
    margin: 0;
    padding: 0;
    background-color: #0a0a0a;
    overflow: hidden;
  }

  footer {
    position: absolute;
    bottom: 25px;
    width: 100%;
    z-index: 10;
    text-align: center;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.4);
    font-family: sans-serif;
  }

  footer a {
    color: inherit;
    text-decoration: none;
    margin: 0 10px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  footer a:hover {
    color: #fff;
  }

  footer img {
    width: 13px;
    height: 13px;
  }
</style>